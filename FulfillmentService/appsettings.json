{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Confluent.Kafka": "Warning"
      }
    },
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "ConnectionStrings": {
    "FulfillmentDatabase": "Host=postgres;Port=5432;Database=orders;Username=postgres;Password=postgres"
  },
  "AllowedHosts": "*",
  "WorkerPool": {
    "WorkerCount": 5,
    "QueueCapacity": 100
  }
}
